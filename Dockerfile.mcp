# MCP HTTP/SSE server for Cursor / Claude Code

FROM node:20-slim AS builder

RUN npm install -g pnpm

WORKDIR /app/mcp

COPY mcp/package.json mcp/tsconfig.json ./
COPY mcp/src ./src

RUN pnpm install && pnpm run build

FROM node:20-slim

WORKDIR /app

COPY --from=builder /app/mcp/dist ./dist
COPY --from=builder /app/mcp/node_modules ./node_modules
COPY --from=builder /app/mcp/package.json ./

EXPOSE 4319

CMD ["node", "dist/index.js"]
