# FastAPI report analysis worker (PCA, k-means, drift/coverage)

FROM python:3.12-slim

WORKDIR /app

COPY server-python/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server-python/aiqa_report_worker ./aiqa_report_worker

ENV PYTHONPATH=/app

EXPOSE 8765

CMD ["uvicorn", "aiqa_report_worker.app:app", "--host", "0.0.0.0", "--port", "8765"]
